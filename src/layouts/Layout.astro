---
import '../styles/global.css';
import { Header } from '../components/Header';
import GeoSchema from '../components/GeoSchema.astro';

interface Props {
    title: string;
    description?: string;
    frontmatter?: any;
    post?: any;
}

const data = Astro.props.post || Astro.props.frontmatter || Astro.props || {};

// Desestruturação limpa (sem duplicações para evitar quebra no Build)
const { title, description } = Astro.props;

// Construtor dinâmico da URL Canônica Oficial
const canonicalURL = new URL(Astro.url.pathname, 'https://maisoninteriorshome.com');
---

<!doctype html>
<html lang="en">
    <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    
    {/* Descrição Dinâmica Otimizada */}
    <meta name="description" content={description || data.meta_description || data.excerpt || "Maison Interiors"} />

    {/* ESCUDO CANÔNICO PARA O GOOGLE SEARCH CONSOLE */}
    <link rel="canonical" href={canonicalURL} />

    <meta name="robots" content="max-image-preview:large" />
    
    {data.featured_image_url && (
        <link 
            rel="preload" 
            as="image" 
            fetchpriority="high"
            imagesrcset={`
                ${data.featured_image_url}&w=400&output=webp 400w,
                ${data.featured_image_url}&w=800&output=webp 800w,
                ${data.featured_image_url}&w=1200&output=webp 1200w
            `}
            imagesizes="(max-width: 768px) 400px, (max-width: 1200px) 800px, 1200px"
        />
    )}

    <link rel="preconnect" href="https://images.weserv.nl" crossorigin />
    <link rel="preconnect" href="https://kqqyqzxkjetvcsnlwqve.supabase.co" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <meta name="p:domain_verify" content="0572834bc69eb23e4732e9266e2fa88f" />

    <GeoSchema 
        title={data.title || title} 
        description={data.meta_description || data.excerpt || data.description} 
        url={`https://maisoninteriorshome.com${Astro.url.pathname}`} 
        image={data.featured_image_url || data.image || 'https://maisoninteriorshome.com/logo.png'} 
        pubDate={data.created_at || data.pubDate || new Date().toISOString()} 
        faqs={data.faqs} 
    />
    </head>
    
    <body class="bg-background text-foreground font-sans antialiased min-h-screen flex flex-col">
        
        {/* Mantendo a hidratação original com client:visible para o Menu Funcionar */}
        <Header client:visible />

        <slot />
        
        <footer class="border-t border-border mt-auto bg-[#FDFDFD]">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 flex flex-col md:flex-row items-center justify-between gap-6">
                
                <div class="font-serif text-2xl tracking-widest text-foreground">
                    MAISON
                </div>

                <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-8 text-[11px] tracking-wider text-muted-foreground uppercase">
                    <a href="/privacy-policy" class="hover:text-foreground transition-colors duration-300">
                        Privacy Policy</a>
                        <a href="/about" class="hover:text-foreground">About Us</a>
                         <a href="/contact" class="hover:text-foreground">Contact</a>
                    
                    <span>
                        &copy; 2026 MAISON INTERIORS. ALL RIGHTS RESERVED.
                    </span>
                </div>

            </div>
        </footer>
        
        <script is:inline>
            let scriptsLoaded = false;
            
            function loadThirdPartyScripts() {
                if (scriptsLoaded) return;
                scriptsLoaded = true;
                
                const adScript = document.createElement('script');
                adScript.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3737276747163019";
                adScript.async = true;
                adScript.crossOrigin = "anonymous";
                document.head.appendChild(adScript);

                (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
                new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
                j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
                'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
                })(window,document,'script','dataLayer','GTM-TS7GMF64');
                
                ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'].forEach(function(e) {
                    window.removeEventListener(e, loadThirdPartyScripts);
                });
            }

            ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'].forEach(function(e) {
                window.addEventListener(e, loadThirdPartyScripts, { passive: true, once: true });
            });
        </script>
        
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TS7GMF64"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    
    </body>
</html>