---
import Layout from '../../layouts/Layout.astro';
import AffiliateProduct from '../../components/AffiliateProduct.astro';
import { supabase } from '../../lib/supabase';
import { Image } from 'astro:assets';

// Busca as rotas e os artigos relacionados
export async function getStaticPaths() {
  const { data: posts, error } = await supabase
    .from('articles')
    .select('*')
    .eq('status', 'published');

  if (error) {
    console.error("Erro na busca:", error);
    return [];
  }

  return posts?.map((post) => {
    // Busca 3 artigos relacionados da mesma categoria (excluindo o atual)
    const relatedPosts = posts
      .filter(p => p.category === post.category && p.slug !== post.slug)
      .slice(0, 3);

    return {
      params: { slug: post.slug },
      props: { post, relatedPosts },
    };
  }) || [];
}

const { post, relatedPosts } = Astro.props;

// --- ESCUDO DE AUDITORIA DO ADSENSE (OCULTAÇÃO DINÂMICA DE AFILIADOS) ---
if (post && post.content) {
  // 1. Achatamento de Links: Remove a tag <a> da Amazon, mantendo apenas o texto âncora limpo.
  post.content = post.content.replace(/<a [^>]*href="[^"]*amazon\.com[^"]*"[^>]*>(.*?)<\/a>/gi, '$1');
  
  // 2. Guilhotina: Corta o artigo exatamente no cabeçalho "Shop This Look" (ou variações) até ao final.
  post.content = post.content.replace(/<h[2-4]>[^<]*Shop This Look[^<]*<\/h[2-4]>[\s\S]*/i, '');
  post.content = post.content.replace(/<h[2-4]>[^<]*Shop The Look[^<]*<\/h[2-4]>[\s\S]*/i, '');
}
// ------------------------------------------------------------------------

// --- TRADUTOR BLINDADO DE FAQ ---
let parsedFaqs = [];
if (post.faqs) {
  try {
    let raw = post.faqs;
    if (typeof raw === 'string') raw = JSON.parse(raw);
    if (typeof raw === 'string') raw = JSON.parse(raw);
    if (Array.isArray(raw)) parsedFaqs = raw;
    else if (raw && typeof raw === 'object') parsedFaqs = [raw];
  } catch (error) {
    let textStr = typeof post.faqs === 'string' ? post.faqs : JSON.stringify(post.faqs);
    const qMatches = [...textStr.matchAll(/"question"\s*:\s*"([^"]+)"/g)];
    const aMatches = [...textStr.matchAll(/"answer"\s*:\s*"([^"]+)"/g)];
    const count = Math.min(qMatches.length, aMatches.length);
    for(let i = 0; i < count; i++) {
      parsedFaqs.push({
         question: qMatches[i][1],
         answer: aMatches[i][1]
      });
    }
  }
}
post.faqs = parsedFaqs.filter(faq => faq.question && faq.answer);
---

<Layout post={post} title={`${post.title} | Maison Interiors`}>
  
  <main class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8 pb-24 pt-16">
    
    <header class="mb-12 max-w-3xl">
      <div class="flex items-center gap-3 text-xs uppercase tracking-widest text-muted-foreground mb-6">
         <span class="font-medium text-foreground">{post.category || 'Design'}</span>
         <span>·</span>
         {post.created_at ? (
           <time datetime={post.created_at}>
             {new Date(post.created_at).toLocaleDateString('en-US', { 
               year: 'numeric', 
               month: 'long', 
               day: 'numeric' 
             })}
           </time>
         ) : (
           <span>Article</span>
         )}
      </div>
      
      <h1 class="text-4xl md:text-[3.5rem] font-serif text-foreground leading-[1.15]" style="font-family: 'Playfair Display', Georgia, serif;">
        {post.title}
      </h1>
    </header>

    {/* CORREÇÃO CRÍTICA 1: Removida a trava antiga. Agora a imagem do cenário gerada pelo Gemini aparece no topo do artigo */}
    {post.featured_image_url && (
      <div class="mb-16 overflow-hidden rounded-sm bg-muted/20">
        <Image 
          src={post.featured_image_url} 
          alt={post.featured_image_alt || `Interior design highlight: ${post.title}`} 
          width={1200} 
          height={675}
          format="webp"
          loading="eager"
          fetchpriority="high"
          class="w-full h-auto object-cover aspect-[16/9]"
        />
      </div>
    )}

    {/* CORREÇÃO CRÍTICA 2: O texto conceitual e educativo do Gemini agora renderiza ANTES do produto para criar o contexto de luxo */}
    <article class="prose prose-stone dark:prose-invert max-w-[680px] mx-auto mt-8 mb-12 text-foreground leading-relaxed text-base" set:html={post.content} />

    {/* Gatilho Condicional: A caixa de produto da Amazon entra logo abaixo do texto como a recomendação natural */}
    {post.is_affiliate && <AffiliateProduct post={post} />}
    
    {/* SEÇÃO DE FAQ */}
    {parsedFaqs.length > 0 && (
        <section class="max-w-[680px] mx-auto mt-20 pt-10 border-t border-border">
            <h2 class="text-2xl font-serif text-foreground mb-8" style="font-family: 'Playfair Display', Georgia, serif;">
                Frequently Asked Questions
            </h2>
            <div class="space-y-8">
                {parsedFaqs.map((faq: any) => (
                    <div class="faq-item">
                        <h3 class="text-lg font-medium text-foreground mb-2">{faq.question}</h3>
                        <p class="text-muted-foreground leading-relaxed">{faq.answer}</p>
                    </div>
                ))}
            </div>
        </section>
    )}

    {/* SEÇÃO DE ARTIGOS RELACIONADOS */}
    {relatedPosts && relatedPosts.length > 0 && (
      <section class="max-w-[1000px] mx-auto mt-24 pt-16 border-t border-border">
        <h2 class="text-2xl font-serif text-foreground mb-10 text-center" style="font-family: 'Playfair Display', Georgia, serif;">
            You May Also Like
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((related: any) => (
            <a href={`/articles/${related.slug}`} class="group block">
              <div class="aspect-[16/9] overflow-hidden rounded-sm mb-4 bg-muted/20">
                <img 
                  src={`https://images.weserv.nl/?url=${related.featured_image_url}&w=400&output=webp`} 
                  alt={related.featured_image_alt || `Interior design highlight: ${related.title}`}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy" 
                />
              </div>
              <h3 class="text-lg font-serif leading-snug group-hover:text-muted-foreground transition-colors" style="font-family: 'Playfair Display', Georgia, serif;">
                {related.title}
              </h3>
            </a>
          ))}
        </div>
      </section>
    )}
    
  </main>
</Layout>