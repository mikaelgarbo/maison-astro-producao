---
const { title, description, url, image, pubDate, faqs } = Astro.props;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": image,
  "author": {
    "@type": "Organization",
    "name": "Maison Interiors",
    "url": "https://maisoninteriorshome.com/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Maison Interiors",
    "logo": {
      "@type": "ImageObject",
      "url": "https://maisoninteriorshome.com/logo.png"
    }
  },
  "datePublished": pubDate,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": url
  }
};

// TRADUTOR DE SUPABASE: Converte texto de volta para Array de FAQs, se necessário
let parsedFaqs = null;
if (faqs) {
  if (typeof faqs === 'string') {
    try { 
      parsedFaqs = JSON.parse(faqs); 
    } catch (e) { 
      console.error("GEO Error: FAQ string is not valid JSON."); 
    }
  } else if (Array.isArray(faqs)) {
    parsedFaqs = faqs;
  }
}

const faqSchema = parsedFaqs && parsedFaqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": parsedFaqs.map((faq: any) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>}